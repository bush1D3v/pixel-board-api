# ─── Server ───
HTTP_PORT=8080
ALLOWED_ORIGIN=*

# ─── PostgreSQL ───
DB_HOST=db
DB_PORT=5432
DB_NAME=pixel_board
DB_USER=pixel
DB_PASSWORD=pixel_secret
DB_POOL_SIZE=10
POSTGRES_DB=pixel_board
POSTGRES_USER=pixel
POSTGRES_PASSWORD=pixel_secret

# ─── Redis ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USER=
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# ─── JWT ───
JWT_ACCESS_KEY=change_me_access_key_super_secret
JWT_REFRESH_KEY=change_me_refresh_key_super_secret

# ─── Logging ───
RUST_LOG=debug

# ─── MinIO (S3-compatible) ───
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pixel-board
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_REGION=us-east-1
